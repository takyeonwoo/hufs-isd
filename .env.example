# 모노레포 루트 .env — Vite(envDir: "..")가 읽는 프론트엔드 환경변수.
# (백엔드는 isd-backend/.env 를 별도로 사용 → isd-backend/.env.example 참고)
#
# 이 파일을 복사해 .env 로 만들고 값을 채우세요:  cp .env.example .env

# 네이버 지도 (Maps JS) Key ID
VITE_NAVER_MAP_KEY_ID=your-naver-map-key-id

# Supabase (프론트 공개용 anon key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
