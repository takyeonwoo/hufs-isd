# Supabase
SUPABASE_URL=https://exwzyohlhywqryhhbvmh.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # 서버 전용. 절대 프론트에 노출 금지
SUPABASE_JWT_SECRET=your-jwt-secret          # Supabase > Settings > API > JWT Secret

# Redis (인기 검색어/랭킹 집계)
REDIS_URL=redis://localhost:6379/0

# CORS 허용 오리진 (콤마 구분)
CORS_ORIGINS=http://localhost:5173

# 개발 편의: true 면 토큰 없이도 가짜 사용자로 통과 (운영에서는 반드시 false)
DEV_FAKE_AUTH=true

# Kakao Local (입점 승인 시 주소 → 좌표 지오코딩). 비우면 매장이 좌표 없이 생성됨.
# Kakao Developers > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=your-kakao-rest-api-key
